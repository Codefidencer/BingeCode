<UserControl x:Class="DevFlix.ToolWindow1Control"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="#141414"
             Foreground="#FFFFFF"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="400"
             Name="MyToolWindow"
             Focusable="True"
             PreviewKeyDown="Control_PreviewKeyDown"
             SizeChanged="OnSizeChanged">

    <UserControl.Resources>

        <Style x:Key="NetflixButton" TargetType="Button">
            <Setter Property="Background"      Value="#E50914"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="4,2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F40612"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B20710"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background"      Value="#2F2F2F"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="4,2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E50914"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NetflixTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#2F2F2F"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="CaretBrush"      Value="#FFFFFF"/>
            <Setter Property="BorderBrush"     Value="#E50914"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="4,2"/>
        </Style>

        <Style x:Key="NetflixComboBox" TargetType="ComboBox">
            <Setter Property="Background"      Value="#2F2F2F"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderBrush"     Value="#E50914"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2F2F2F"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="Padding"    Value="6,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E50914"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#B20710"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="4,2"/>
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0"
                                                      Stroke="#E50914" StrokeThickness="2"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="6,2,24,2"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide" Placement="Bottom"
                                   Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                <Border Background="#2F2F2F" BorderBrush="#E50914" BorderThickness="1" CornerRadius="0,0,3,3">
                                    <ScrollViewer MaxHeight="300">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Full toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Mini exit strip (fullscreen only) -->
            <RowDefinition Height="*"/>     <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── Full toolbar ── -->
        <StackPanel x:Name="Toolbar" Grid.Row="0" Background="#141414">

            <!-- Row 1: window picker + refresh + fullscreen + stop -->
            <Grid Margin="6,6,6,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="WindowPicker" Grid.Column="0"
                          Style="{StaticResource NetflixComboBox}"
                          SelectionChanged="WindowPicker_SelectionChanged"
                          ToolTip="Select a video window to mirror"/>

                <Button Grid.Column="1" Content="&#8635;" Width="28" Margin="4,0,0,0"
                        Style="{StaticResource IconButton}"
                        Click="RefreshWindows_Click" ToolTip="Refresh window list"/>

                <Button Grid.Column="2" Content="&#9645;" Width="28" Margin="4,0,0,0"
                        Style="{StaticResource IconButton}"
                        Click="ToggleFullscreen_Click" ToolTip="Toggle fullscreen"/>

                <Button Grid.Column="3" Content="&#10005;" Width="28" Margin="4,0,0,0"
                        Style="{StaticResource IconButton}"
                        Click="StopContent_Click" ToolTip="Stop and clear content"/>
            </Grid>

            <!-- Row 2: URL input + Go + open file -->
            <Grid Margin="6,3,6,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UrlInput" Grid.Column="0"
                         Style="{StaticResource NetflixTextBox}"
                         KeyDown="UrlInput_KeyDown"
                         ToolTip="Paste a URL — opens in your browser and auto-mirrors"/>

                <Button Grid.Column="1" Content="Go" Width="36" Margin="4,0,0,0"
                        Style="{StaticResource NetflixButton}"
                        Click="LoadUrl_Click"/>

                <Button Grid.Column="2" Content="..." Width="28" Margin="4,0,0,0"
                        Style="{StaticResource IconButton}"
                        Click="OpenFile_Click" ToolTip="Open local video file"/>
            </Grid>
        </StackPanel>

        <!-- ── Mini exit strip — visible only in fullscreen ── -->
        <Border x:Name="MiniBar" Grid.Row="1" Visibility="Collapsed"
                Background="#0D0D0D" Height="20">
            <Button Content="▲ Exit fullscreen" HorizontalAlignment="Right"
                    Margin="0,0,4,0" FontSize="10" Height="18"
                    Style="{StaticResource IconButton}"
                    Click="ToggleFullscreen_Click"/>
        </Border>

        <!-- ── Content area ── -->
        <Border x:Name="ContentBorder" Grid.Row="2"
                BorderThickness="1" BorderBrush="#E50914">
            <Grid x:Name="ContentGrid"
                  Focusable="True"
                  MouseLeftButtonDown="ContentArea_DoubleClick"
                  MouseMove="ContentArea_MouseMove">

                <!-- Placeholder — logo integrated into background -->
                <Grid x:Name="Placeholder">
                    <!-- Dark gradient background matching logo -->
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0A0A0A" Offset="0"/>
                                <GradientStop Color="#1A1A1A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Left accent stripe -->
                    <Rectangle HorizontalAlignment="Left" Width="5">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF0F1A" Offset="0"/>
                                <GradientStop Color="#B20710" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Right accent stripe -->
                    <Rectangle HorizontalAlignment="Right" Width="5">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF0F1A" Offset="0"/>
                                <GradientStop Color="#B20710" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Top accent line -->
                    <Rectangle VerticalAlignment="Top" Height="3" Margin="5,0,5,0" Fill="#4DE50914"/>

                    <!-- Bottom accent line -->
                    <Rectangle VerticalAlignment="Bottom" Height="3" Margin="5,0,5,0" Fill="#4DE50914"/>

                    <!-- Subtle horizontal rule -->
                    <Rectangle VerticalAlignment="Center" Height="1" Margin="20,0,20,0" Fill="#26E50914"/>

                    <!-- Centered logo text and hints -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="PlaceholderTitle"
                                   Text="&lt;/DevFlix&gt;"
                                   FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   FontFamily="Courier New, Consolas, Lucida Console">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF0F1A" Offset="0"/>
                                    <GradientStop Color="#B20710" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="WATCH WHILE YOU CODE"
                                   FontSize="9" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" Opacity="0.38"
                                   Foreground="#FFFFFF"/>
                        <TextBlock x:Name="PlaceholderHint"
                                   Text="Pick a video window above, paste a URL, or open a local file."
                                   FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="16,20,16,0" Opacity="0.5" Foreground="#FFFFFF"/>
                        <TextBlock Text="Double-click to toggle fullscreen"
                                   FontSize="10" HorizontalAlignment="Center"
                                   Margin="0,6,0,0" Opacity="0.3" Foreground="#FFFFFF"/>
                    </StackPanel>
                </Grid>

                <!-- WebView2 (Edge Chromium) for URLs and local files -->
                <wv2:WebView2 x:Name="Browser" Visibility="Collapsed"/>

                <!-- DWM thumbnail mirror fills this area -->
                <Border x:Name="ThumbnailArea" Visibility="Collapsed"
                        Background="#000000"/>

            </Grid>
        </Border>
    </Grid>
</UserControl>
